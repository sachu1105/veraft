# Contact form delivery (Resend — https://resend.com)
# Copy this file to `.env.local` and fill in the values.

# Required. Create at https://resend.com/api-keys
RESEND_API_KEY=

# Optional. Inbox that receives contact submissions.
# Defaults to `site.email` in lib/site.ts if unset.
CONTACT_TO=veraftio@gmail.com

# Optional. Sender address — must be on a domain verified in Resend.
# Leave unset to use Resend's shared testing sender (onboarding@resend.dev).
# CONTACT_FROM=Veraft <hello@yourdomain.com>
